# Copy this file to .env.local (which is gitignored) and fill in the real values
# from your Supabase project's Settings -> API Keys page.
#
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are safe to expose to
# the browser -- Row Level Security policies protect the data, not this key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SUPABASE_SERVICE_ROLE_KEY -- bypasses Row Level Security entirely. Used only
# by server-side code (the /api/auth/* login/signup routes, via lib/supabase/admin.ts)
# to create accounts and check MPINs. Must NEVER be prefixed with NEXT_PUBLIC_,
# must never be committed, and must never be sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
