# Copy this file to .env.local (which is gitignored) and fill in the real values
# from your Supabase project's Settings -> API page.
#
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are safe to expose to
# the browser -- Row Level Security policies protect the data, not this key.
#
# Never put the service_role key in this file or in any NEXT_PUBLIC_* variable.
# This project's design does not need the service_role key anywhere in the app.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
